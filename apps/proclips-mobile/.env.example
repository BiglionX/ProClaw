# ============================================
# ProClaw Mobile - 环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填入实际值。
# cp .env.example .env.local
#
# EXPO_PUBLIC_ 前缀的变量会在构建时注入到应用代码中，
# 可通过 process.env.EXPO_PUBLIC_XXX 访问。
# ============================================

# ---------- AI / LLM ----------
# DeepSeek API 密钥（用于 Agent 智能对话）
# 获取地址：https://platform.deepseek.com/api_keys
# 优先级：安全存储 > 此环境变量
EXPO_PUBLIC_AI_API_KEY=sk-your-deepseek-api-key

# API 地址（可选，默认：https://api.deepseek.com）
EXPO_PUBLIC_AI_API_BASE=https://api.deepseek.com

# 模型名称（可选，默认：deepseek-chat）
EXPO_PUBLIC_AI_MODEL=deepseek-chat

# ---------- ProClips 后端（独立子项目，不复用 ProClaw 主后端）----------
# ProClips 视频营销后端 base URL。
# 开发：可指向本地 dev 服务或 EAS preview 环境
# 生产：必须为 HTTPS 域名（与 nginx.conf 反代后的 PUBLIC_BASE_URL 一致）
#
# ★ 推荐在 EAS Build 中走 Secrets 管理（不要硬编码到 .env）：
#   eas env:create --name EXPO_PUBLIC_PROCLIPS_API_BASE \
#                  --value https://api-proclips.example.com \
#                  --environment production --visibility secret
# ★ 本地 dev 调试时填入内网 IP（手机/模拟器可访问）：
EXPO_PUBLIC_PROCLIPS_API_BASE=http://10.0.2.2:4000

# ---------- Supabase ----------
# 云存储/备份服务（可选，用于数据同步）
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------- 桌面端配对（可选）----------
# 手机独立版首次打开无需配对；需要与桌面同步/通话时：
# 设置 → 配对桌面端，输入桌面端 6 位配对码（或扫码）
# 服务器地址通常为 http://<desktop-ip>:8888
