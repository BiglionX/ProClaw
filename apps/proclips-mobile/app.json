{
  "expo": {
    "name": "ProClips",
    "slug": "proclips-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/proclips-logo.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "assets": [
      "./assets/fonts"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.proclips.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ProClips 需要使用麦克风进行语音通话",
        "NSCameraUsageDescription": "ProClips 需要使用摄像头进行视频通话"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/proclips-logo.png",
        "backgroundColor": "#6366f1",
        "monochromeImage": "./assets/proclips-logo.png"
      },
      "package": "com.proclips.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/proclips-logo.png",
      "splash": {
        "image": "./assets/proclips-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#6366f1"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/AntDesign.ttf",
            "./assets/fonts/Entypo.ttf",
            "./assets/fonts/EvilIcons.ttf",
            "./assets/fonts/Feather.ttf",
            "./assets/fonts/FontAwesome.ttf",
            "./assets/fonts/FontAwesome5_Brands.ttf",
            "./assets/fonts/FontAwesome5_Regular.ttf",
            "./assets/fonts/FontAwesome5_Solid.ttf",
            "./assets/fonts/FontAwesome6_Brands.ttf",
            "./assets/fonts/FontAwesome6_Regular.ttf",
            "./assets/fonts/FontAwesome6_Solid.ttf",
            "./assets/fonts/Fontisto.ttf",
            "./assets/fonts/Foundation.ttf",
            "./assets/fonts/Ionicons.ttf",
            "./assets/fonts/MaterialCommunityIcons.ttf",
            "./assets/fonts/MaterialIcons.ttf",
            "./assets/fonts/Octicons.ttf",
            "./assets/fonts/SimpleLineIcons.ttf",
            "./assets/fonts/Zocial.ttf"
          ]
        }
      ],
      "@livekit/react-native-expo-plugin"
    ],
    "extra": {
      "eas": {
        "projectId": "09c592c9-01be-4eb0-bf85-25b804ea67e7"
      }
    },
    "owner": "biglionx"
  }
}
