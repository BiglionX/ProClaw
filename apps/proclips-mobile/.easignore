# EAS Build archive 阶段忽略规则
# 语法同 .gitignore，参考 https://docs.expo.dev/build-reference/easignore/

# Qoder IDE 缓存
.qoder/
../.qoder/

# 本地调试日志与解压中间产物
dist-*/
dist-eas-log*.txt
dist-eas-log*.gz

# EAS Build archive 不需要的内容
node_modules/
.expo/
*.log
*.tmp
.cache/

# 测试文件 - 不需要上传到构建服务器
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# 临时文件
*.swp
*.swo
*~

# 编辑器配置
.vscode/
.idea/
*.iml

# 构建产物
web-build/
dist/

# macOS
.DS_Store

# 环境变量
.env*.local