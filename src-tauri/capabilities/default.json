{
  "identifier": "default",
  "description": "Default capabilities for ProClaw",
  "windows": ["main", "setup-wizard"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-ask",
    "dialog:allow-message",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-stat",
    "fs:allow-mkdir",
    "fs:scope-app-recursive",
    "fs:scope-data-recursive",
    "fs:scope-download-recursive",
    "shell:default",
    "shell:allow-open"
  ]
}
