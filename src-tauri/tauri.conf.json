{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProClaw",
  "version": "1.1.1",
  "identifier": "com.proclaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ProClaw Desktop",
        "url": "#/teams",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "focus": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.deepseek.com https://api.openai.com https://ai.proclaw.cc https://nvwa.proclaw.cc https://dashscope.aliyuncs.com https://open.bigmodel.cn https://api.pexels.com https://api.openverse.org https://pixabay.com https://releases.proclaw.cc http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob: https:; font-src 'self' data:; media-src 'self' blob:; frame-src 'self' https://*.proclaw.cc",
      "dangerousDisableAssetCspModification": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.proclaw.cc/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5MTFFQjcwRTZCMEU4QUUKUldTdTZMRG1jT3NST1lOZ09sMWVFeG53OU9seWZpbVg1R054bnpSSlpXMkU2TEpoRVBqb3V4aloK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Copyright © 2026 ProClaw",
    "category": "Business",
    "shortDescription": "ProClaw - AI-Powered Business Operating System",
    "longDescription": "ProClaw is an AI-powered business operating system for small merchants. It features local-first data storage, AI order recognition, inventory management, and optional cloud backup.",
    "windows": {
      "nsis": {
        "languages": [
          "English",
          "SimpChinese"
        ],
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3"
        ]
      }
    }
  }
}
