{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProClaw",
  "version": "0.1.0",
  "identifier": "com.proclaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProClaw Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
