{
  "name": "proclaw-mobile",
  "version": "1.0.0",
  "description": "ProClaw Mobile App - 商务通移动端",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest --forceExit --detectOpenHandles",
    "typecheck": "tsc --noEmit",
    "lint:no-console": "node scripts/lint-no-console.js",
    "lint:check": "npm run typecheck && npm run lint:no-console",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "axios": "^1.7.0",
    "crypto-js": "^4.2.0",
    "expo": "^56.0.9",
    "expo-camera": "~56.0.7",
    "expo-file-system": "~56.0.7",
    "expo-image-picker": "~56.0.16",
    "expo-modules-autolinking": "^56.0.15",
    "expo-network": "~56.0.5",
    "expo-secure-store": "~56.0.4",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "jszip": "^3.10.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-incall-manager": "^4.2.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-paper": "^5.12.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-toast-message": "^2.2.0",
    "react-native-vector-icons": "^10.0.0",
    "react-native-web": "^0.21.2",
    "react-native-webrtc": "^124.0.0",
    "react-native-webview": "^13.16.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-native-vector-icons": "^6.4.18",
    "jest": "^29.7.0",
    "patch-package": "^8.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "moduleNameMapper": {
      "^@react-native-async-storage/async-storage$": "<rootDir>/node_modules/@react-native-async-storage/async-storage",
      "^react-native$": "<rootDir>/__mocks__/react-native.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|expo|@expo)/)"
    ],
    "testEnvironment": "node"
  },
  "private": true,
  "expo": {
    "name": "ProClaw Mobile",
    "slug": "proclaw-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.proclaw.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ProClaw 需要使用麦克风进行语音通话",
        "NSCameraUsageDescription": "ProClaw 需要使用摄像头进行视频通话"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.proclaw.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "react-native-webrtc",
        {
          "cameraPermission": "ProClaw 需要使用摄像头进行视频通话",
          "microphonePermission": "ProClaw 需要使用麦克风进行语音通话"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    }
  }
}
