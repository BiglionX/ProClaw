{
  "expo": {
    "name": "ProClaw Mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/proclaw-logo.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.proclaw.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ProClaw 需要使用麦克风进行语音通话",
        "NSCameraUsageDescription": "ProClaw 需要使用摄像头进行视频通话"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/proclaw-logo.png",
        "backgroundColor": "#6366f1",
        "monochromeImage": "./assets/proclaw-logo.png"
      },
      "package": "com.proclaw.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/proclaw-logo.png",
      "splash": {
        "image": "./assets/proclaw-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#6366f1"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "09c592c9-01be-4eb0-bf85-25b804ea67e7"
      }
    },
    "owner": "biglionx"
  }
}
