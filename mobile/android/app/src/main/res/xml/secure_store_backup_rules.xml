<?xml version="1.0" encoding="utf-8"?>
<!--
  Android < 12 的 Auto Backup 规则 (fullBackupContent)
  expo-secure-store 推荐规则：排除 AndroidKeystore 加密的 SharedPreferences，
  防止从云备份恢复时加密密钥丢失导致数据无法解密。
  对应文档: https://docs.expo.dev/versions/latest/sdk/securestore/
-->
<full-backup-content>
  <!-- 排除 expo-secure-store 加密数据（包含 Android Keystore 加密的 SharedPreferences） -->
  <exclude domain="sharedpref" path="SecureStore.pb" />
  <exclude domain="sharedpref" path="SecureStore.xml" />
  <!-- 排除 SQLite 数据库（多身份 profile 数据，包含同步元数据） -->
  <exclude domain="database" />
  <exclude domain="database" path="RKStorage" />
  <!-- 排除缓存与外部缓存 -->
  <exclude domain="external" path="." />
</full-backup-content>
