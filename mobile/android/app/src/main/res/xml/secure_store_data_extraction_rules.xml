<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) 的 D2D 设备传输和云备份数据提取规则 (dataExtractionRules)
  与 fullBackupContent 语义类似，但走 Android 12+ 的新数据迁移机制。
  expo-secure-store / expo-sqlite 加密数据不应参与云备份或设备迁移。
-->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="sharedpref" path="SecureStore.pb" />
    <exclude domain="sharedpref" path="SecureStore.xml" />
    <exclude domain="database" />
    <exclude domain="database" path="RKStorage" />
    <exclude domain="external" path="." />
  </cloud-backup>
  <device-transfer>
    <exclude domain="sharedpref" path="SecureStore.pb" />
    <exclude domain="sharedpref" path="SecureStore.xml" />
    <exclude domain="database" />
    <exclude domain="database" path="RKStorage" />
    <exclude domain="external" path="." />
  </device-transfer>
</data-extraction-rules>
