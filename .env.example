# Supabase Configuration (可选，不配置则使用本地模式)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 演示模式 (设置为 true 可跳过 Supabase 配置)
VITE_DEMO_MODE=false

# Application Configuration
VITE_APP_NAME=ProClaw
VITE_APP_VERSION=0.1.0-beta

# 云商城公网地址（演示商城路径：https://proclaw.cc/demo，由 cloud-store 项目绑定 proclaw.cc 域名）
# VITE_CLOUD_STORE_URL=https://proclaw.cc

# Build Mode: 'inventory' (进销存版) or 'virtual_company' (虚拟公司版)
# VITE_BUILD_MODE=inventory

# AI Team 群聊 LLM 兜底配置（可选，用户可在设置页覆盖）
# VITE_LLM_API_KEY=sk-your-api-key
# VITE_LLM_API_BASE=https://api.deepseek.com
# VITE_LLM_MODEL=deepseek-chat
