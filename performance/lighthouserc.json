{
  "ci": {
    "collect": {
      "url": "http://localhost:3000",
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": ["--disable-gpu", "--headless"]
      }
    },
    "assert": {
      "budgets": [
        {
          "path": "/*",
          "resourceSizes": [
            { "resourceType": "total", "budget": "1500kb" },
            { "resourceType": "script", "budget": "500kb" },
            { "resourceType": "style", "budget": "100kb" }
          ],
          "resourceCounts": [
            { "resourceType": "total", "budget": 30 },
            { "resourceType": "third-party", "budget": 5 }
          ]
        }
      ],
      "performance": ["warn: 0.7", "error: 0.5"],
      "accessibility": ["warn: 0.8", "error: 0.6"],
      "best-practices": ["warn: 0.8", "error: 0.6"],
      "seo": ["warn: 0.8", "error: 0.6"]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
