{
  "name": "proclaw-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "proclaw:start": "npm --workspace proclaw-mobile start",
    "proclaw:apk": "npm --workspace proclaw-mobile run build:apk",
    "proclips:start": "npm --workspace proclips-mobile start",
    "proclips:apk": "npm --workspace proclips-mobile run build:apk"
  },
  "engines": {
    "node": ">=18"
  }
}
