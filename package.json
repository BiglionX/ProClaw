{
  "name": "@proclaw/desktop",
  "version": "1.0.8",
  "description": "ProClaw - AI-Powered Business Operating System",
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:tauri": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "bump:version": "node scripts/bump-version.mjs",
    "copy:release": "node scripts/copy-release.mjs",
    "release:desktop": "node scripts/bump-version.mjs && npm run tauri build && node scripts/copy-release.mjs",
    "setup:updater-keys": "tauri signer generate -w %USERPROFILE%/.tauri/proclaw-updater.key --ci",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:run && npm run test:e2e"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.40",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.4",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@typescript-eslint/parser": "^8.62.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.6.0",
    "date-fns": "^3.0.0",
    "eslint": "^10.5.0",
    "framer-motion": "^12.40.0",
    "langchain": "^1.3.3",
    "livekit-client": "^2.19.2",
    "postcss": "^8.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^3.8.1",
    "simple-statistics": "^7.8.9",
    "tailwindcss": "^3.4.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.11.1",
    "jsdom": "^24.0.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
