# ============================================
# ProClips Backend 环境变量样例
# 复制为 .env 后填入实际值
# ============================================

# HTTP 服务
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# JWT 鉴权（与移动端 ApiService 共享密钥，长度 ≥ 32 字节）
JWT_SECRET=please-change-me-to-a-32-byte-random-string
JWT_ISSUER=proclips-backend

# 数据库与存储
DB_PATH=./data/db.sqlite
UPLOAD_DIR=./data/uploads
RESULT_DIR=./data/results
LOG_DIR=./data/logs

# 公开访问前缀（用于拼下载 URL）
PUBLIC_BASE_URL=http://localhost:4000

# 混剪任务 Worker
MIX_WORKER_INTERVAL_MS=2000
MIX_TASK_MOCK_DURATION_SEC=30

# CORS（生产填移动端 origin）
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# 限流
RATE_LIMIT_PER_MINUTE=60

# ============================================
# ★★★ 生产环境切换清单（部署到线上时必改） ★★★
# ============================================
# 1) 生成 JWT_SECRET（务必 ≥32 字节随机）：
#      openssl rand -base64 48
# 2) NODE_ENV=production（zod 会强制校验 JWT_SECRET ≥16 字符）
# 3) PUBLIC_BASE_URL 改成 HTTPS 公网域名，例如：
#      https://api-proclips.example.com
#    （用于拼下载/分享/海报 URL，一旦定下不可随意改）
# 4) CORS_ORIGINS 改成移动端实际请求源：
#      https://app.example.com,https://expo.dev,https://*.expo.dev
# 5) 关闭 mock 时长（生产可保留小一些）：
#      MIX_TASK_MOCK_DURATION_SEC=30
# 6) 如启用对象存储（V2），再追加：
#      OSS_BUCKET=...
#      OSS_ACCESS_KEY=...
#      OSS_SECRET_KEY=...
#
# 提示：.env 已在 .gitignore 内，勿提交到仓库。
